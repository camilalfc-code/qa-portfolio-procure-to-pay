  "item": [
    {
      "name": "01 - Login do Usuário (Autenticação)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Verifica se o status é 200\r",
              "pm.test(\"Status 200 - Login realizado com sucesso\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// Verifica se o token foi retornado\r",
              "pm.test(\"Token retornado na resposta\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.authorization).to.be.a(\"string\");\r",
              "});\r",
              "\r",
              "// Salva o token na variável de ambiente\r",
              "const json = pm.response.json();\r",
              "if (json.authorization) {\r",
              "    pm.environment.set(\"token\", json.authorization);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"email\": \"{{email_comprador}}\",\r\n  \"password\": \"{{senha_comprador}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "02 - Cadastrar Usuário (Comprador)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Verifica se o status é 201 - Criado\r",
              "pm.test(\"Status 201 - Usuário cadastrado com sucesso\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "// Verifica se a mensagem de sucesso foi retornada\r",
              "pm.test(\"Mensagem de sucesso retornada\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.message).to.eql(\"Cadastro realizado com sucesso\");\r",
              "});\r",
              "\r",
              "// Salva o ID do usuário na variável de ambiente\r",
              "const json = pm.response.json();\r",
              "if (json._id) {\r",
              "    pm.environment.set(\"usuario_id\", json._id);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const timestamp = Date.now();\r",
              "pm.environment.set(\"email_comprador\", `comprador.${timestamp}@p2p.com.br`);\r",
              "pm.environment.set(\"senha_comprador\", \"teste123\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"nome\": \"Camila Compradora\",\r\n  \"email\": \"{{email_comprador}}\",\r\n  \"password\": \"{{senha_comprador}}\",\r\n  \"administrador\": \"true\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
